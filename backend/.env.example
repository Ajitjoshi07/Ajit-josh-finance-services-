# Application
APP_NAME="Ajit Joshi Finance Services"
APP_VERSION="1.0.0"
DEBUG=true
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/ajit_finance_db
ASYNC_DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/ajit_finance_db

# Redis
REDIS_URL=redis://localhost:6379/0

# File Storage (local for dev, S3 for prod)
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=./uploads
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=ajit-finance-docs
AWS_REGION=ap-south-1

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@ajitjoshifinance.com

# Anthropic AI (for chatbot)
ANTHROPIC_API_KEY=your-anthropic-api-key

# GSTN API
GSTN_API_URL=https://api.example-gstn.gov.in
GSTN_API_KEY=your-gstn-api-key

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Security
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
